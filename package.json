{
  "name": "sudo-play",
  "version": "1.0.2",
  "description": "Terminal powered mini games for developers. Zero graphics. Maximum pain.",
  "main": "index.js",
  "files": [
    "dist"
  ],
  "keywords": [
    "cli",
    "game",
    "terminal",
    "developer",
    "arcade",
    "npx",
    "typescript"
  ],
  "author": "sheikhnz",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepublishOnly": "npm run build",
    "build": "tsc",
    "start": "node ./dist/bin/sudo-play.js",
    "dev": "tsx ./bin/sudo-play.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pr-preflight": "npm run format && npm run lint:fix",
    "clean": "rm -rf dist node_modules",
    "fresh": "npm run clean && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sheikhnz/sudo-play.git"
  },
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/sheikhnz/sudo-play/issues"
  },
  "homepage": "https://github.com/sheikhnz/sudo-play#readme",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "bin": {
    "sudo-play": "dist/bin/sudo-play.js"
  }
}
